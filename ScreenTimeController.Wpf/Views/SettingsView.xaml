<Window x:Class="ScreenTimeController.Wpf.Views.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ScreenTimeController.Wpf.MarkupExtensions"
        Title="{local:Localize ScreenTimeSettings}" 
        Height="600" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        FontSize="14"
        KeyDown="OnKeyDown">
    
    <Window.Resources>
        <Style x:Key="LightButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#C8C8C8"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D8D8D8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="PrimaryLightButtonStyle" TargetType="Button" BasedOn="{StaticResource LightButtonStyle}">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0098FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TabControl Grid.Row="0" Background="White">
            <TabItem Header="{local:Localize DailyLimit}">
                <ScrollViewer Padding="10">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding DayLimits}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0" 
                                                   Text="{Binding DayName}" 
                                                   FontSize="14" 
                                                   VerticalAlignment="Center"/>
                                        
                                        <TextBox Grid.Column="1" 
                                                 Text="{Binding Hours, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="14" 
                                                 TextAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 Margin="0,0,5,0"/>
                                        
                                        <TextBlock Grid.Column="2" 
                                                   Text="{local:Localize Hours}" 
                                                   FontSize="12" 
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,5,0"/>
                                        
                                        <TextBox Grid.Column="3" 
                                                 Text="{Binding Minutes, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="14" 
                                                 TextAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 Margin="0,0,5,0"/>
                                        
                                        <TextBlock Grid.Column="4" 
                                                   Text="{local:Localize Minutes}" 
                                                   FontSize="12" 
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <Button Content="{local:Localize ApplyToAllDays}"
                                Style="{StaticResource LightButtonStyle}"
                                Command="{Binding ApplyToAllCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,20,0,0"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <TextBlock Text="{local:Localize Language}" 
                                       FontSize="14" 
                                       VerticalAlignment="Center"
                                       Width="100"/>
                            <ComboBox Width="200"
                                      ItemsSource="{Binding Languages}"
                                      SelectedIndex="{Binding SelectedLanguageIndex}"/>
                        </StackPanel>
                        
                        <CheckBox Content="{local:Localize EnablePasswordLock}"
                                  IsChecked="{Binding EnablePasswordLock}"
                                  Margin="0,20,0,0"
                                  FontSize="14"/>
                        
                        <Button Content="{local:Localize PasswordSettings}"
                                Style="{StaticResource LightButtonStyle}"
                                Command="{Binding ChangePasswordCommand}"
                                HorizontalAlignment="Left"
                                Margin="0,20,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <TabItem Header="{local:Localize Applications}">
                <TextBlock Text="{local:Localize AppLimitsDescription}"
                           FontSize="14"
                           Margin="20"
                           TextWrapping="Wrap"/>
            </TabItem>
        </TabControl>
        
        <StackPanel Grid.Row="1" Margin="0,20,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12"
                       Foreground="#28A745"
                       Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"
                       Margin="0,0,0,10"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="{local:Localize OK}"
                        Style="{StaticResource PrimaryLightButtonStyle}"
                        Command="{Binding OKCommand}"
                        Width="100" Margin="0,0,20,0"/>
                
                <Button Content="{local:Localize Cancel}"
                        Style="{StaticResource LightButtonStyle}"
                        Command="{Binding CancelCommand}"
                        Width="100"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
