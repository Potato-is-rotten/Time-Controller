<Window x:Class="ScreenTimeController.Wpf.Views.UnlockView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ScreenTimeController.Wpf.MarkupExtensions"
        Title="{local:Localize AppTitle}" 
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#1E1E1E"
        ResizeMode="NoResize"
        FontSize="14"
        KeyDown="OnKeyDown">
    
    <Window.Resources>
        <Style x:Key="DarkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#505050"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#606060"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DarkButtonStyle}">
            <Setter Property="Background" Value="#007ACC"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0098FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource DarkButtonStyle}">
            <Setter Property="Background" Value="#28A745"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34C759"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Border Background="#323232" 
                CornerRadius="8"
                Width="500" Height="400"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" 
                           Text="{local:Localize AppTitle}"
                           FontSize="20" FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                
                <TextBlock Grid.Row="1" 
                           Text="{local:Localize TimeExpired}"
                           FontSize="16" 
                           Foreground="#FF6464"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
                
                <StackPanel Grid.Row="2" 
                            Visibility="{Binding ShowingPasswordPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                    
                    <TextBlock Text="{local:Localize EnterPasswordToUnlock}"
                               FontSize="14" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    
                    <PasswordBox x:Name="PasswordBox"
                                 Width="400" Height="40"
                                 FontSize="16"
                                 HorizontalAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,10"/>
                    
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="12" Foreground="#FF6464"
                               HorizontalAlignment="Center"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"
                               Margin="0,0,0,10"/>
                    
                    <Button Content="{local:Localize Unlock}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding UnlockCommand}"
                            Width="200" Height="50"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,0"/>
                </StackPanel>
                
                <StackPanel Grid.Row="2" 
                            Visibility="{Binding ShowingBonusOptions, Converter={StaticResource BoolToVisibilityConverter}}">
                    
                    <TextBlock Text="{local:Localize SelectBonusTime}"
                               FontSize="14" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    
                    <ComboBox x:Name="BonusTimeComboBox"
                              Width="400" Height="40"
                              FontSize="16"
                              HorizontalAlignment="Center"
                              ItemsSource="{Binding BonusTimeOptions}"
                              SelectedIndex="{Binding SelectedBonusTimeIndex}"
                              Margin="0,0,0,20"/>
                    
                    <Button Content="{local:Localize AddBonusTime}"
                            Style="{StaticResource SuccessButtonStyle}"
                            Command="{Binding AddTimeCommand}"
                            Width="200" Height="50"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
